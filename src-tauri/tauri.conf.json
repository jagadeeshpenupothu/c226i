{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrintPilot",
  "version": "0.1.0",
  "identifier": "com.printpilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PrintPilot",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null
    },
    "resources": [],
    "icon": []
  }
}
