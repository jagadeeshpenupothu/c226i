# PrintPilot — Firebase configuration (email/password auth + cloud PDF archive)
#
# Copy this file to `.env.local` and fill in the values from your Firebase
# project (Project settings → General → Your apps → SDK setup and configuration).
#
# These are Vite env vars: only variables prefixed with VITE_ are exposed to the
# app, and only via import.meta.env inside the cloud bootstrap. They are NOT
# secrets — a Firebase web config is safe to ship in a client; access is gated by
# Firebase Auth + Security Rules, not by hiding these values.
#
# If these are absent, PrintPilot still opens the guest/local workflow. Sign-in
# and Cloud Documents report that no cloud provider is configured.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
